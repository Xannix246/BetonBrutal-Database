datasource db {
    provider = "mongodb"
    url      = env("DATABASE_URL")
}

generator client {
    provider = "prisma-client-js"
}

model SteamUser {
    id       String         @id @default(auto()) @map("_id") @db.ObjectId
    steamId  String         @unique
    username String
    items    String[]
    replays  String[]
}

model WorkshopItem {
    id         String    @id @default(auto()) @map("_id") @db.ObjectId
    title      String
    steamId    String    @unique
    creator    String
    creatorId  String
    createDate DateTime  @default(now())
    ratingUp   Int       @default(0)
    ratingDown Int       @default(0)
    previewUrl String
    previews   String[]
}

model LeaderboardEntry {
    id        String    @id @default(auto()) @map("_id") @db.ObjectId
    mapId     String
    steamId   String
    username  String
    score     Int
    date      DateTime?

    @@unique([mapId, steamId])
}

model Leaderboard {
    id        String    @id @default(auto()) @map("_id") @db.ObjectId
    mapId     String    @unique
    enteries  String[] //LeaderboardEntry id's
}

