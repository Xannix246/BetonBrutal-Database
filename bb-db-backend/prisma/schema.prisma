datasource db {
    provider = "mongodb"
    url      = env("DATABASE_URL")
}

generator client {
    provider = "prisma-client-js"
}

model SteamUser {
    id       String   @id @default(auto()) @map("_id") @db.ObjectId
    steamId  String   @unique
    username String
    items    String[]
    replays  String[]
}

model WorkshopItem {
    id         String   @id @default(auto()) @map("_id") @db.ObjectId
    title      String
    steamId    String   @unique
    creator    String
    creatorId  String
    createDate DateTime @default(now())
    ratingUp   Int      @default(0)
    ratingDown Int      @default(0)
    previewUrl String
    previews   String[]
}

model LeaderboardEntry {
    id       String    @id @default(auto()) @map("_id") @db.ObjectId
    place    Int
    mapId    String
    steamId  String
    username String
    score    Int
    replayId String?
    date     DateTime?
    banned   Boolean   @default(false)

    @@unique([mapId, steamId])
}

model Leaderboard {
    id       String   @id @default(auto()) @map("_id") @db.ObjectId
    mapId    String   @unique
    enteries String[] //LeaderboardEntry id's
}

model Comment {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    mapId     String
    userId    String
    data      String
    createdAt DateTime @default(now())
}

model Favorites {
    id     String   @id @default(auto()) @map("_id") @db.ObjectId
    userId String   @unique
    mapsId String[]
}

enum Color {
    white
    black
    red
    blue
    green
    yellow
}

model Collection {
    id          String   @id @default(auto()) @map("_id") @db.ObjectId
    title       String
    description String?
    mapsId      String[]
    showOnMain  Boolean  @default(false)
    descColor   Color    @default(black)
}

// Better Auth models

enum Role {
    user
    admin
    moderator
    writer
}

model User {
    id            String    @id @map("_id")
    name          String
    email         String
    emailVerified Boolean   @default(false)
    image         String?
    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @default(now()) @updatedAt
    role          Role      @default(user)
    sessions      Session[]
    accounts      Account[]

    banned     Boolean?  @default(false)
    banReason  String?
    banExpires DateTime?

    @@unique([email])
    @@map("user")
}

model Session {
    id        String   @id @map("_id")
    expiresAt DateTime
    token     String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    ipAddress String?
    userAgent String?
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    impersonatedBy String?

    @@unique([token])
    @@map("session")
}

model Account {
    id                    String    @id @map("_id")
    accountId             String
    providerId            String
    userId                String
    user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    accessToken           String?
    refreshToken          String?
    idToken               String?
    accessTokenExpiresAt  DateTime?
    refreshTokenExpiresAt DateTime?
    scope                 String?
    password              String?
    createdAt             DateTime  @default(now())
    updatedAt             DateTime  @updatedAt

    @@map("account")
}

model Verification {
    id         String   @id @map("_id")
    identifier String
    value      String
    expiresAt  DateTime
    createdAt  DateTime @default(now())
    updatedAt  DateTime @default(now()) @updatedAt

    @@map("verification")
}

// internal data like news/articles and nominees

model Nominees {
    id            String   @id @default(auto()) @map("_id") @db.ObjectId
    name          String
    internal_name String?  @unique
    description   String?
    maps          String[]
}

type AttachmentHeader {
    name String
    url  String
}

model Article {
    id          String             @id @default(auto()) @map("_id") @db.ObjectId
    authorId    String
    title       String
    description String?
    content     String
    date        DateTime
    tags        String[]
    preview     String? // attachment id
    attachments AttachmentHeader[] // attachment ids
}

model Attachment {
    id       String @id @default(auto()) @map("_id") @db.ObjectId
    name     String
    fileId   String // id from gridfs
    mimeType String
    size     Int?
}
